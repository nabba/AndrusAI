# ─── LLM Provider ─────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Search ──────────────────────────────────────────────
BRAVE_API_KEY=your_brave_search_api_key_here
# Get free key at: https://api.search.brave.com/

# ─── Signal ──────────────────────────────────────────────
SIGNAL_BOT_NUMBER=+1XXXXXXXXXX        # Bot's dedicated phone number
SIGNAL_OWNER_NUMBER=+1XXXXXXXXXX      # Your personal iPhone number
SIGNAL_CLI_PATH=/opt/homebrew/bin/signal-cli
SIGNAL_SOCKET_PATH=/tmp/signal-cli.sock

# ─── Gateway ─────────────────────────────────────────────
GATEWAY_SECRET=generate_a_64_char_random_string_here
GATEWAY_PORT=8765
GATEWAY_BIND=127.0.0.1                # NEVER change to 0.0.0.0

# ─── Models ──────────────────────────────────────────────
COMMANDER_MODEL=claude-opus-4-6
SPECIALIST_MODEL=claude-sonnet-4-6

# ─── Docker Sandbox ──────────────────────────────────────
SANDBOX_IMAGE=crewai-sandbox:latest
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=0.5

# ─── Self-Improvement Schedule ───────────────────────────
SELF_IMPROVE_CRON=0 3 * * *           # Daily at 03:00
SELF_IMPROVE_TOPIC_FILE=workspace/skills/learning_queue.md
